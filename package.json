{
	"name": "aintools-discord",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy",
		"register": "bun --env-file=.dev.vars scripts/register.ts",
		"register:prod": "REGISTER_SCOPE=global bun --env-file=.env.prod scripts/register.ts",
		"extract-course": "bun scripts/extract-course.ts",
		"test": "bun test",
		"check": "biome check --write .",
		"typecheck": "wrangler types && tsc --noEmit",
		"migrate:local": "wrangler d1 migrations apply aintools-discord --local",
		"migrate:remote": "wrangler d1 migrations apply aintools-discord --remote"
	},
	"dependencies": {
		"discord-hono": "^0.21.2"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@types/bun": "^1.3.14",
		"lefthook": "^2.1.9",
		"typescript": "^6.0.3",
		"wrangler": "^4.107.0"
	}
}
