{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "aintools-discord",
	"main": "src/index.ts",
	"compatibility_date": "2026-07-01",
	"compatibility_flags": ["nodejs_compat"],
	"observability": {
		"enabled": true
	},

	// Custom domain, flipped on at cutover (PR-9) once the old docker-compose bot
	// is ready to retire. Until then the workers.dev URL is the staging endpoint.
	// "routes": [
	// 	{
	// 		"pattern": "bot.aynu.org",
	// 		"custom_domain": true
	// 	}
	// ], // enable at cutover (PR-9)

	// Non-secret config. Secrets (DISCORD_TOKEN, DISCORD_PUBLIC_KEY,
	// DISCORD_APPLICATION_ID) are set via `wrangler secret put`.
	"vars": {
		"CORPUS_API_URL": "https://corpus.aynu.org",
		"MDB_API_URL": "https://mdb.aynu.org",
		"GLOSSARY_API_URL": "https://itak.aynu.org/api/gdoc",
		// Empty ⇒ WOTD cron no-ops safely (set once a post channel is chosen).
		"WOTD_CHANNEL_ID": "",
		"AI_GATEWAY_ID": "aintools-discord",
		"ASK_MODEL": "@cf/openai/gpt-oss-120b",
		"ASK_COOLDOWN_SECONDS": "300"
	},

	// Glossary stale-while-revalidate cache (key "glossary:v1"); reused by
	// /ask cooldowns in a later PR.
	"kv_namespaces": [
		{
			"binding": "KV",
			"id": "19c3ae65776d40338bf281b5b577738c"
		}
	]

	// d1_databases / ai / services / triggers land in their respective
	// feature PRs (see rewrite plan PR sequence).
}
